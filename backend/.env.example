# 应用配置
APP_NAME=NeikongAI
APP_ENV=development
DEBUG=True
SECRET_KEY=change-this-to-random-secret-key-in-production

# 数据库配置
DATABASE_URL=postgresql://neikongai_user:your_password_here@localhost:5432/neikongai
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# MinIO 配置
MINIO_ENDPOINT=s3.neikongai.com
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_SECURE=True
MINIO_REGION=us-east-1

# ChromaDB 配置
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_PERSIST_DIRECTORY=/var/www/neikongai/storage/chromadb

# JWT 配置
JWT_SECRET_KEY=change-this-to-random-jwt-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 文件上传配置
MAX_UPLOAD_SIZE=104857600
ALLOWED_EXTENSIONS=pdf,doc,docx,xls,xlsx,txt,jpg,jpeg,png,zip

# CORS 配置
ALLOWED_ORIGINS=https://neikongai.com,https://www.neikongai.com

# 平台配置
PLATFORM_LEGAL_BUCKET=platform-legal-docs

# 独立的数据库连接参数（用于 psycopg2）
DB_HOST=localhost
DB_PORT=5432
DB_NAME=neikongai
DB_USER=neikongai_user
DB_PASSWORD=your_password_here

# DashScope（通义千问）API Key
DASHSCOPE_API_KEY=your-dashscope-api-key-here
