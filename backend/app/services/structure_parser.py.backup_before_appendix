"""
结构识别服务
识别法律文档的章、节、条、款、项结构
结合规则识别和AI辅助识别
"""

import re
from typing import Dict, List, Tuple
from dashscope import Generation
import os
import json


class StructureParser:
    """结构解析器：识别法律文档的层级结构"""
    
    def __init__(self):
        self.chapter_pattern = re.compile(r'第[一二三四五六七八九十百千\d]+章')
        self.section_pattern = re.compile(r'第[一二三四五六七八九十百千\d]+节')
        self.article_pattern = re.compile(r'第[一二三四五六七八九十百千零\d]+条')
        
        # 附则、附件模式
        self.appendix_pattern = re.compile(r'附\s*则|附\s*件[一二三四五\d]*|附\s*表[一二三四五\d]*')
        
        # 引用关系模式
        self.reference_patterns = [
            re.compile(r'依照[本]?[法律]*第[一二三四五六七八九十百千零\d]+条'),
            re.compile(r'参照[本]?[法律]*第[一二三四五六七八九十百千零\d]+条'),
            re.compile(r'按照[本]?[法律]*第[一二三四五六七八九十百千零\d]+条'),
            re.compile(r'根据[本]?[法律]*第[一二三四五六七八九十百千零\d]+条'),
        ]
    
    def parse_structure(self, text: str, use_ai: bool = True) -> Dict:
        """
        解析文档结构（规则 + AI）
        
        Args:
            text: 文档全文
            use_ai: 是否使用AI辅助识别
            
        Returns:
            {
                'chapters': [...],
                'sections': [...],
                'articles': [...],
                'references': {...},
                'attachments': [...]
            }
        """
        print("\n🔍 开始识别文档结构...")
        
        result = {
            'chapters': [],
            'sections': [],
            'articles': [],
            'references': {},
            'attachments': []
        }
        
        # 1. 规则识别
        print("   📋 步骤1: 规则识别（正则表达式）...")
        result.update(self.identify_by_rules(text))
        
        print(f"      ✅ 识别到 {len(result['chapters'])} 个章")
        print(f"      ✅ 识别到 {len(result['sections'])} 个节")
        print(f"      ✅ 识别到 {len(result['articles'])} 个条")
        
        # 2. 提取引用关系
        print("   🔗 步骤2: 提取引用关系...")
        result['references'] = self.extract_references(text)
        print(f"      ✅ 识别到 {len(result['references'])} 个引用")
        
        # 3. AI辅助识别（可选）
        if use_ai and len(result['articles']) > 0:
            print("   🤖 步骤3: AI辅助识别主题...")
            try:
                ai_result = self.identify_by_ai(text, result['articles'])
                
                # 将AI识别的主题添加到文章信息中
                for article in result['articles']:
                    article_num = article['number']
                    if article_num in ai_result:
                        article['topic'] = ai_result[article_num].get('topic', '')
                        article['keywords'] = ai_result[article_num].get('keywords', [])
                
                print(f"      ✅ AI识别完成")
            except Exception as e:
                print(f"      ⚠️  AI识别失败（跳过）: {e}")
        
        print("✅ 结构识别完成\n")
        
        return result
    
    def identify_by_rules(self, text: str) -> Dict:
        """
        规则识别：使用正则表达式识别章节条
        
        Args:
            text: 文档全文
            
        Returns:
            包含章、节、条信息的字典
        """
        lines = text.split('\n')
        
        chapters = []
        sections = []
        articles = []
        attachments = []
        
        current_chapter = None
        current_section = None
        
        for i, line in enumerate(lines):
            line = line.strip()
            if not line:
                continue
            
            # 识别章
            chapter_match = self.chapter_pattern.match(line)
            if chapter_match:
                chapter_number = chapter_match.group()
                # 章标题可能在同一行或下一行
                chapter_title = line[len(chapter_number):].strip()
                
                current_chapter = {
                    'number': chapter_number,
                    'title': chapter_title,
                    'line_num': i + 1
                }
                chapters.append(current_chapter)
                current_section = None  # 新章节重置节
                continue
            
            # 识别节
            section_match = self.section_pattern.match(line)
            if section_match:
                section_number = section_match.group()
                section_title = line[len(section_number):].strip()
                
                current_section = {
                    'number': section_number,
                    'title': section_title,
                    'chapter': current_chapter['number'] if current_chapter else None,
                    'line_num': i + 1
                }
                sections.append(current_section)
                continue
            
            # 识别条
            article_match = self.article_pattern.match(line)
            if article_match:
                article_number = article_match.group()
                
                # 提取条文内容（可能跨多行）
                article_content = self._extract_article_content(lines, i)
                
                article_info = {
                    'number': article_number,
                    'content': article_content,
                    'chapter': current_chapter['number'] if current_chapter else None,
                    'section': current_section['number'] if current_section else None,
                    'line_num': i + 1
                }
                articles.append(article_info)
                continue
            
            # 识别附则/附件
            appendix_match = self.appendix_pattern.search(line)
            if appendix_match:
                attachments.append({
                    'type': appendix_match.group(),
                    'line_num': i + 1,
                    'content': line
                })
        
        return {
            'chapters': chapters,
            'sections': sections,
            'articles': articles,
            'attachments': attachments
        }
    
    def _extract_article_content(self, lines: List[str], start_index: int) -> str:
        """
        提取条文完整内容（可能跨多行）
        从"第X条"开始，到下一个"第X条"或章节标题为止
        
        Args:
            lines: 所有行
            start_index: 条文开始行的索引
            
        Returns:
            条文完整内容
        """
        content_parts = [lines[start_index].strip()]
        
        # 向后查找，直到遇到下一个条文或章节
        for i in range(start_index + 1, len(lines)):
            line = lines[i].strip()
            
            if not line:
                continue
            
            # 遇到下一个结构元素，停止
            if (self.article_pattern.match(line) or 
                self.chapter_pattern.match(line) or 
                self.section_pattern.match(line) or
                self.appendix_pattern.search(line)):
                break
            
            content_parts.append(line)
        
        return ' '.join(content_parts)
    
    def extract_references(self, text: str) -> Dict:
        """
        提取引用关系："依照第X条"、"参照第X条"等
        
        Args:
            text: 文档全文
            
        Returns:
            {
                '第五十条': ['第十条', '第四十五条'],
                ...
            }
        """
        references = {}
        
        # 按条分割文本
        articles = self.article_pattern.split(text)
        article_numbers = self.article_pattern.findall(text)
        
        for i, article_num in enumerate(article_numbers):
            if i + 1 < len(articles):
                article_content = articles[i + 1]
                
                # 查找所有引用
                referenced_articles = []
                
                for pattern in self.reference_patterns:
                    matches = pattern.findall(article_content)
                    for match in matches:
                        # 提取被引用的条号
                        ref_article = re.search(r'第[一二三四五六七八九十百千零\d]+条', match)
                        if ref_article:
                            referenced_articles.append(ref_article.group())
                
                if referenced_articles:
                    references[article_num] = list(set(referenced_articles))
        
        return references
    
    def identify_by_ai(self, text: str, articles: List[Dict], sample_size: int = 10) -> Dict:
        """
        AI辅助识别：识别条款主题和关键词
        注意：为了节省API调用，只分析前N条作为示例
        
        Args:
            text: 文档全文
            articles: 已识别的条文列表
            sample_size: 采样数量（避免API调用过多）
            
        Returns:
            {
                '第一条': {'topic': '立法目的', 'keywords': ['劳动合同', '权益保护']},
                ...
            }
        """
        if not articles:
            return {}
        
        # 只分析前N条（节省API调用）
        sample_articles = articles[:sample_size]
        
        # 构建prompt
        articles_text = '\n\n'.join([
            f"{art['number']} {art['content'][:200]}..."  # 每条只取前200字
            for art in sample_articles
        ])
        
        prompt = f"""请分析以下法律条文，为每一条提取：
1. 主题（用3-5个字概括）
2. 关键词（2-3个）

条文内容：
{articles_text}

请以JSON格式返回，格式如下：
{{
  "第一条": {{"topic": "立法目的", "keywords": ["劳动合同", "权益保护"]}},
  "第二条": {{"topic": "适用范围", "keywords": ["用人单位", "劳动者"]}}
}}

只返回JSON，不要其他内容。
"""
        
        try:
            response = Generation.call(
                model='qwen-turbo',
                messages=[{'role': 'user', 'content': prompt}],
                result_format='message'
            )
            
            if response.status_code == 200:
                content = response.output.choices[0].message.content
                
                # 提取JSON（可能包含markdown代码块）
                json_match = re.search(r'\{.*\}', content, re.DOTALL)
                if json_match:
                    result = json.loads(json_match.group())
                    return result
                else:
                    return {}
            else:
                return {}
                
        except Exception as e:
            print(f"      AI识别异常: {e}")
            return {}
    
    def get_article_by_number(self, articles: List[Dict], article_number: str) -> Dict:
        """
        根据条号获取条文内容
        
        Args:
            articles: 条文列表
            article_number: 条号（如"第三十九条"）
            
        Returns:
            条文信息
        """
        for article in articles:
            if article['number'] == article_number:
                return article
        return None


# 创建全局实例
structure_parser = StructureParser()


