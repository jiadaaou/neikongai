<template>
  <div class="laws-page">
    <el-card class="page-header" shadow="never">
      <div class="page-header-content">
        <div>
          <h2 class="page-title">法律文档管理</h2>
          <p class="page-desc">请先选择法律层级，再进行上传、查询和管理。</p>
        </div>
      </div>
    </el-card>

    <el-row :gutter="16" class="level-grid">
      <el-col v-for="item in levelCards" :key="item.value" :xs="24" :sm="12" :md="8" :lg="8" :xl="4">
        <el-card
          shadow="hover"
          class="level-card"
          :class="{ active: selectedLevel === item.value }"
          @click="selectLevelCard(item.value)"
        >
          <div class="level-card-inner">
            <div class="level-card-top">
              <span class="level-badge">L{{ item.value }}</span>
              <el-tag :type="selectedLevel === item.value ? 'primary' : 'info'" size="small">
                {{ item.short }}
              </el-tag>
            </div>
            <h3 class="level-title">{{ item.label }}</h3>
            <p class="level-desc">{{ item.desc }}</p>
            <div class="level-card-footer">
              <span>{{ selectedLevel === item.value ? '当前已选中' : '点击进入管理' }}</span>
            </div>
          </div>
        </el-card>
      </el-col>
    </el-row>

    <el-card class="toolbar" shadow="never">
      <div class="toolbar-content">
        <div class="toolbar-left">
          <el-alert
            v-if="selectedLevel"
            :title="`当前层级：${selectedLevelName}`"
            type="success"
            :closable="false"
            class="current-level-alert"
          />

          <el-input
            v-model="searchQuery"
            placeholder="搜索法律名称"
            style="width: 300px"
            clearable
            @keyup.enter="handleSearch"
          >
            <template #prefix>
              <el-icon><Search /></el-icon>
            </template>
          </el-input>

          <el-select
            v-model="selectedLevel"
            placeholder="法律层级"
            clearable
            style="width: 150px"
            @change="handleLevelChange"
          >
            <el-option v-for="item in levelCards" :key="item.value" :label="item.label" :value="item.value" />
          </el-select>

          <el-button type="primary" @click="handleSearch">
            <el-icon><Search /></el-icon>
            搜索
          </el-button>

          <el-button @click="resetFilters">
            重置
          </el-button>
        </div>

        <div class="toolbar-right">
          <el-button type="primary" @click="openUploadDialog">
            <el-icon><Upload /></el-icon>
            上传法律文档
          </el-button>
        </div>
      </div>
    </el-card>

    <el-alert
      v-if="uploadingDocs.length > 0"
      title="文档处理中"
      type="info"
      :closable="false"
      style="margin-bottom: 20px;"
    >
      <template #default>
        <div v-for="doc in uploadingDocs" :key="doc.id" class="uploading-item">
          <div class="uploading-item-top">
            <span>📄 {{ doc.title }}</span>
            <el-tag type="warning" size="small">处理中...</el-tag>
          </div>
          <el-progress
            :percentage="doc.progress"
            :status="doc.status"
            style="margin-top: 5px;"
          />
        </div>
      </template>
    </el-alert>

    <el-card class="table-card" shadow="never">
      <template #header>
        <div class="table-header">
          <span>{{ selectedLevelName ? `${selectedLevelName}列表` : '全部法律文档' }}</span>
          <span class="table-header-sub">共 {{ total }} 条</span>
        </div>
      </template>

      <el-table
        v-loading="loading"
        :data="tableData"
        stripe
        style="width: 100%"
      >
        <el-table-column prop="id" label="ID" width="80" />
        <el-table-column prop="title" label="法律名称" min-width="260" />
        <el-table-column prop="legal_level_name" label="法律层级" width="120" />
        <el-table-column prop="processed_status" label="处理状态" width="120">
          <template #default="{ row }">
            <el-tag v-if="row.processed_status === 'completed'" type="success">已完成</el-tag>
            <el-tag v-else-if="row.processed_status === 'processing'" type="warning">处理中</el-tag>
            <el-tag v-else-if="row.processed_status === 'pending'" type="info">等待中</el-tag>
            <el-tag v-else type="danger">失败</el-tag>
          </template>
        </el-table-column>
        <el-table-column prop="effective_date" label="生效日期" width="140">
          <template #default="{ row }">
            {{ formatShortDate(row.effective_date) }}
          </template>
        </el-table-column>
        <el-table-column prop="chunks_count" label="分块数" width="100" />
        <el-table-column prop="uploaded_at" label="上传时间" width="180">
          <template #default="{ row }">
            {{ formatDate(row.uploaded_at) }}
          </template>
        </el-table-column>
        <el-table-column label="操作" width="180" fixed="right">
          <template #default="{ row }">
            <el-button link type="primary" @click="viewDetail(row.id)">
              <el-icon><View /></el-icon>
              详情
            </el-button>
            <el-button link type="danger" @click="handleDelete(row)">
              <el-icon><Delete /></el-icon>
              删除
            </el-button>
            <el-button
              v-if="row.processed_status === 'failed'"
              link
              type="warning"
              @click="handleReprocess(row)"
            >
              <el-icon><RefreshRight /></el-icon>
              重新分块
            </el-button>
          </template>
        </el-table-column>
      </el-table>

      <div class="pagination">
        <el-pagination
          v-model:current-page="currentPage"
          v-model:page-size="pageSize"
          :total="total"
          :page-sizes="[10, 20, 50, 100]"
          layout="total, sizes, prev, pager, next, jumper"
          @current-change="fetchData"
          @size-change="fetchData"
        />
      </div>
    </el-card>

    <el-dialog
      v-model="dialogVisible"
      title="上传法律文档"
      width="600px"
      destroy-on-close
    >
      <el-form
        ref="uploadFormRef"
        :model="uploadForm"
        :rules="uploadRules"
        label-width="100px"
      >
        <el-form-item label="法律名称" prop="title">
          <el-input v-model="uploadForm.title" placeholder="请输入法律名称" />
        </el-form-item>

        <el-form-item label="法律层级" prop="legal_level">
          <el-select v-model="uploadForm.legal_level" placeholder="请选择法律层级">
            <el-option v-for="item in levelCards" :key="item.value" :label="item.label" :value="item.value" />
          </el-select>
        </el-form-item>

        <el-form-item label="生效日期" prop="effective_date">
          <el-date-picker
            v-model="uploadForm.effective_date"
            type="date"
            placeholder="选择日期"
            value-format="YYYY-MM-DD"
            style="width: 100%;"
          />
        </el-form-item>

        <el-form-item label="文件" prop="file">
          <el-upload
            ref="uploadRef"
            :auto-upload="false"
            :limit="1"
            :on-change="handleFileChange"
            accept=".pdf,.docx,.doc,.txt"
            drag
          >
            <el-icon class="el-icon--upload"><UploadFilled /></el-icon>
            <div class="el-upload__text">
              拖拽文件到此处或<em>点击上传</em>
            </div>
            <template #tip>
              <div class="el-upload__tip">
                支持 PDF、Word、TXT 格式，文件大小不超过 50MB
              </div>
            </template>
          </el-upload>
        </el-form-item>
      </el-form>

      <template #footer>
        <el-button @click="dialogVisible = false">取消</el-button>
        <el-button type="primary" :loading="uploading" @click="handleUpload">
          上传
        </el-button>
      </template>
    </el-dialog>
  </div>
</template>

<script setup>
import { ref, computed, onMounted } from 'vue'
import { useRouter } from 'vue-router'
import { ElMessage, ElMessageBox } from 'element-plus'
import { Search, Upload, View, Delete, UploadFilled, RefreshRight } from '@element-plus/icons-vue'
import { getLawsList, uploadLaw, deleteLaw, getLawDetail, reprocessDocument } from '@/api/laws'

const router = useRouter()

const levelCards = [
  { value: 5, label: '宪法', short: '最高层级', desc: '国家根本法，作为检索与合规判断的最终兜底。' },
  { value: 4, label: '法律', short: '国家法律', desc: '全国人大及其常委会制定，作为核心法源。' },
  { value: 3, label: '行政法规', short: '国务院', desc: '国务院制定，承接法律并细化执行要求。' },
  { value: 2, label: '部门规章', short: '部委规则', desc: '财政部、司法部等部门制定，贴近业务执行。' },
  { value: 1, label: '地方法规', short: '地方适用', desc: '各地区法规文件，适用于属地化合规管理。' }
]

const searchQuery = ref('')
const selectedLevel = ref(null)

const loading = ref(false)
const tableData = ref([])
const currentPage = ref(1)
const pageSize = ref(20)
const total = ref(0)

const dialogVisible = ref(false)
const uploading = ref(false)
const uploadingDocs = ref([])
const uploadFormRef = ref(null)
const uploadRef = ref(null)

const createDefaultUploadForm = () => ({
  title: '',
  legal_level: selectedLevel.value || null,
  effective_date: '',
  file: null
})

const uploadForm = ref(createDefaultUploadForm())

const uploadRules = {
  title: [{ required: true, message: '请输入法律名称', trigger: 'blur' }],
  legal_level: [{ required: true, message: '请选择法律层级', trigger: 'change' }]
}

const selectedLevelName = computed(() => {
  const current = levelCards.find((item) => item.value === selectedLevel.value)
  return current ? current.label : ''
})

const resetUploadForm = () => {
  uploadForm.value = createDefaultUploadForm()
  if (uploadFormRef.value) {
    uploadFormRef.value.resetFields()
  }
  if (uploadRef.value) {
    uploadRef.value.clearFiles()
  }
}

const openUploadDialog = () => {
  resetUploadForm()
  dialogVisible.value = true
}

const selectLevelCard = (level) => {
  selectedLevel.value = level
  currentPage.value = 1
  fetchData()
}

const handleLevelChange = () => {
  currentPage.value = 1
  fetchData()
}

const resetFilters = () => {
  searchQuery.value = ''
  selectedLevel.value = null
  currentPage.value = 1
  fetchData()
}

const fetchData = async () => {
  loading.value = true
  try {
    const params = {
      page: currentPage.value,
      per_page: pageSize.value,
      search: searchQuery.value || undefined,
      legal_level: selectedLevel.value || undefined
    }

    const res = await getLawsList(params)
    tableData.value = Array.isArray(res.data) ? res.data : []
    total.value = res.total || 0
  } catch (error) {
    console.error('获取数据失败：', error)
    ElMessage.error('获取法律列表失败')
  } finally {
    loading.value = false
  }
}

const handleSearch = () => {
  currentPage.value = 1
  fetchData()
}

const viewDetail = (id) => {
  router.push(`/admin/laws/${id}`)
}

const handleDelete = async (row) => {
  try {
    await ElMessageBox.confirm(
      `确定要删除 "${row.title}" 吗？此操作不可恢复！`,
      '警告',
      {
        confirmButtonText: '确定',
        cancelButtonText: '取消',
        type: 'warning'
      }
    )

    await deleteLaw(row.id)
    ElMessage.success('删除成功')
    fetchData()
  } catch (error) {
    if (error !== 'cancel') {
      console.error('删除失败：', error)
      ElMessage.error('删除失败')
    }
  }
}

const handleReprocess = async (row) => {
  try {
    await ElMessageBox.confirm(
      `确定要重新处理 "${row.title}" 吗？这将重新分块和向量化。`,
      '确认',
      {
        confirmButtonText: '确定',
        cancelButtonText: '取消',
        type: 'info'
      }
    )

    await reprocessDocument(row.id)
    ElMessage.success('已提交重新处理请求')
    fetchData()
  } catch (error) {
    if (error !== 'cancel') {
      console.error('重新处理失败：', error)
      ElMessage.error('重新处理失败')
    }
  }
}

const handleFileChange = (file) => {
  uploadForm.value.file = file.raw
}

const handleUpload = async () => {
  if (!uploadFormRef.value) return

  try {
    await uploadFormRef.value.validate()

    if (!uploadForm.value.file) {
      ElMessage.warning('请选择要上传的文件')
      return
    }

    uploading.value = true

    const formData = new FormData()
    formData.append('file', uploadForm.value.file)
    formData.append('title', uploadForm.value.title)
    formData.append('legal_level', uploadForm.value.legal_level)

    if (uploadForm.value.effective_date) {
      formData.append('effective_date', uploadForm.value.effective_date)
    }

    const docTitle = uploadForm.value.title
    dialogVisible.value = false

    const uploadId = Date.now()
    uploadingDocs.value.push({
      id: uploadId,
      title: docTitle,
      progress: 10,
      status: 'warning'
    })

    const res = await uploadLaw(formData)

    const doc = uploadingDocs.value.find((item) => item.id === uploadId)
    if (doc) {
      doc.progress = 50
    }

    ElMessage.success('上传成功！文档正在后台处理...')
    resetUploadForm()

    if (res.document_id) {
      startPolling(uploadId, res.document_id)
    }

    fetchData()
  } catch (error) {
    console.error('上传失败：', error)
    ElMessage.error(error?.response?.data?.detail || '上传失败')
  } finally {
    uploading.value = false
  }
}

const startPolling = async (uploadId, documentId) => {
  const maxAttempts = 60
  let attempts = 0

  const poll = async () => {
    try {
      attempts += 1
      const detail = await getLawDetail(documentId)
      const doc = uploadingDocs.value.find((item) => item.id === uploadId)

      if (!doc) return

      if (detail.processed_status === 'completed') {
        doc.progress = 100
        doc.status = 'success'

        setTimeout(() => {
          const index = uploadingDocs.value.findIndex((item) => item.id === uploadId)
          if (index > -1) {
            uploadingDocs.value.splice(index, 1)
          }
        }, 3000)

        ElMessage.success(`${doc.title} 处理完成！`)
        fetchData()
        return
      }

      if (detail.processed_status === 'failed') {
        doc.progress = 100
        doc.status = 'exception'

        ElMessage.error(`${doc.title} 处理失败`)

        setTimeout(() => {
          const index = uploadingDocs.value.findIndex((item) => item.id === uploadId)
          if (index > -1) {
            uploadingDocs.value.splice(index, 1)
          }
        }, 5000)

        fetchData()
        return
      }

      if (detail.processed_status === 'processing') {
        if (doc.progress < 90) {
          doc.progress += 5
        }
      } else if (doc.progress < 70) {
        doc.progress += 3
      }

      if (attempts < maxAttempts) {
        setTimeout(poll, 3000)
      } else {
        doc.status = 'exception'
        ElMessage.warning(`${doc.title} 处理超时，请刷新查看`)
      }
    } catch (error) {
      console.error('轮询失败：', error)

      if (attempts < maxAttempts) {
        setTimeout(poll, 3000)
      } else {
        const doc = uploadingDocs.value.find((item) => item.id === uploadId)
        if (doc) {
          doc.status = 'exception'
        }
      }
    }
  }

  poll()
}

const formatDate = (dateStr) => {
  if (!dateStr) return '-'
  return new Date(dateStr).toLocaleString('zh-CN')
}

const formatShortDate = (dateStr) => {
  if (!dateStr) return '-'
  return dateStr
}

onMounted(() => {
  fetchData()
})
</script>

