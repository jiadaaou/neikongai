<template>
  <div class="law-detail">
    <el-page-header @back="goBack" title="返回" content="法律文档详情" />
    
    <el-card v-loading="loading" class="detail-card" shadow="never">
      <template #header>
        <div class="card-header">
          <h3>{{ lawDetail.title }}</h3>
          <el-tag v-if="lawDetail.processed_status === 'completed'" type="success">已完成</el-tag>
          <el-tag v-else-if="lawDetail.processed_status === 'processing'" type="warning">处理中</el-tag>
          <el-tag v-else-if="lawDetail.processed_status === 'pending'" type="info">等待处理</el-tag>
          <el-tag v-else type="danger">处理失败</el-tag>
        </div>
      </template>
      
      <el-descriptions :column="2" border>
        <el-descriptions-item label="法律层级">
          {{ lawDetail.legal_level_name }}
        </el-descriptions-item>
        <el-descriptions-item label="文号">
          {{ lawDetail.doc_number || '-' }}
        </el-descriptions-item>
        <el-descriptions-item label="生效日期">
          {{ lawDetail.effective_date || '-' }}
        </el-descriptions-item>
        <el-descriptions-item label="上传时间">
          {{ formatDate(lawDetail.uploaded_at) }}
        </el-descriptions-item>
        <el-descriptions-item label="原始文件名">
          {{ lawDetail.original_filename }}
        </el-descriptions-item>
        <el-descriptions-item label="分块数量">
          {{ lawDetail.chunks_count || 0 }}
        </el-descriptions-item>
      </el-descriptions>
    </el-card>
    
    <el-card class="chunks-card" shadow="never">
      <template #header>
        <h3>文档分块（{{ chunks.length }}个）</h3>
      </template>
      
      <el-table :data="chunks" stripe>
        <el-table-column prop="chunk_index" label="序号" width="80" />
        <el-table-column prop="chunk_type" label="类型" width="120">
          <template #default="{ row }">
            {{ row.chunk_type === 'single_article' ? '单条' : '条组' }}
          </template>
        </el-table-column>
        <el-table-column prop="chapter_number" label="章节" width="100" />
        <el-table-column prop="article_start" label="条款" width="120" />
        <el-table-column prop="chunk_text" label="内容" min-width="300">
          <template #default="{ row }">
            {{ row.chunk_text.substring(0, 100) }}...
          </template>
        </el-table-column>
        <el-table-column label="关键词" width="200">
          <template #default="{ row }">
            <el-tag
              v-for="keyword in row.keywords"
              :key="keyword"
              size="small"
              style="margin-right: 5px"
            >
              {{ keyword }}
            </el-tag>
          </template>
        </el-table-column>
      </el-table>
    </el-card>
  </div>
</template>

<script setup>
import { ref, onMounted } from 'vue'
import { useRoute, useRouter } from 'vue-router'
import { getLawDetail, getLawChunks } from '@/api/laws'

const route = useRoute()
const router = useRouter()

const loading = ref(false)
const lawDetail = ref({})
const chunks = ref([])

const goBack = () => {
  router.back()
}

const formatDate = (dateStr) => {
  if (!dateStr) return '-'
  return new Date(dateStr).toLocaleString('zh-CN')
}

const fetchData = async () => {
  loading.value = true
  try {
    const id = route.params.id
    
    // 获取详情
    const detail = await getLawDetail(id)
    lawDetail.value = detail
    
    // 获取分块
    const chunksData = await getLawChunks(id)
    chunks.value = chunksData.chunks || []
  } catch (error) {
    console.error('获取详情失败：', error)
  } finally {
    loading.value = false
  }
}

onMounted(() => {
  fetchData()
})
</script>

<style scoped>
.law-detail {
  display: flex;
  flex-direction: column;
  gap: 20px;
}

.card-header {
  display: flex;
  align-items: center;
  gap: 15px;
}

.card-header h3 {
  margin: 0;
  flex: 1;
}

.detail-card,
.chunks-card {
  margin-top: 20px;
}
</style>
